mixin selectTree(category, level, parent_id)
    each item in category 
        -const prefix = Array(level + 1).join("-- ")
        option(
            value = item._id
            selected=(item.id == parent_id)
        ) #{prefix}#{item.name}
        -if(item.children && item.children.length > 0)
            +selectTree(item.children, level+1, parent_id)
