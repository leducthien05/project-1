extends ../../layout/default.pug
include ../../mixin/filterStatus.pug
include ../../mixin/search.pug
include ../../mixin/pagination.pug
include ../../mixin/OptionChangeMulti.pug
include ../../mixin/alert.pug

block main
    +success(3000)
    .card.shadow-sm.mb-3
        .card-header
            h5.mb-0 Chi tiết sản phẩm

        .card-body
            .row

                // Ảnh sản phẩm
                .col-md-4.text-center
                    if product.image
                        img(class="img-fluid rounded"
                            src=product.image
                            style="max-height:300px;object-fit:contain"
                        )
                    else
                        img(class="img-fluid rounded"
                            src="https://via.placeholder.com/300"
                        )

                // Thông tin sản phẩm
                .col-md-8

                    h4.mb-3 #{product.name}

                    .mb-2
                        strong Giá:
                        span.text-success.ms-2 #{product.price} VNĐ

                    .mb-2
                        strong Giảm giá:
                        span.ms-2 #{product.discountPercentage} %

                    .mb-2
                        strong Danh mục:
                        span.ms-2 #{product.category}

                    .mb-2
                        strong Vị trí:
                        span.ms-2 #{product.position}

                    .mb-3
                        strong Trạng thái:

                        if product.status == "active"
                            span.badge.bg-success.ms-2 Hoạt động
                        else
                            span.badge.bg-danger.ms-2 Ngừng hoạt động

                    .mt-3
                        a(
                            class = "btn btn-warning"
                            href=`${prefixAdmin}/products/edit/${product._id}`
                        ) Chỉnh sửa

                        a(
                            class= "btn btn-secondary ms-2"
                            href=`${prefixAdmin}/products`
                        ) Quay lại


    .card.shadow-sm
    .card-header
        h6.mb-0 Mô tả sản phẩm

    .card-body
        p !{product.description}