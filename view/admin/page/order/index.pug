extends ../../layout/default.pug
include ../../mixin/filterStatus.pug
include ../../mixin/search.pug
include ../../mixin/pagination.pug
include ../../mixin/OptionChangeMulti.pug
include ../../mixin/alert.pug
include ../../mixin/sort.pug
include ../../mixin/convertTime.pug
include ../../mixin/report.pug

block main
    +success(3000)
    if(roleAccount.permission.includes("order_view"))
        .row.mb-4
            +report(order)
            
            .card.shadow-sm
                .card-body
                    h5.mb-3 Bộ lọc và Tìm kiếm
                        .row.align-items-center
                            // Bộ lọc trạng thái
                            .col-md-4
                                +filterStatusOrder(listStatusOrder)
                            .col-md-4
                                +sortOrder
                            .col-md-4
                                +search(keyword)
        .card.shadow-sm.mb-3
            .card-header.d-flex.justify-content-between.align-items-center
                h5.mb-0 Danh sách đơn hàng
                // Select hành động
                if(roleAccount.permission.includes("order_edit"))
                    form(
                        action=`${prefixAdmin}/orders/change-multi-status?_method=PATCH` 
                        method="POST" 
                        form-change-multi
                        class="d-flex gap-2"
                    )
                        +selectOptionOrder()
            .card-body

                table(
                    class="table table-hover"
                )
                    thead
                        th
                            input(
                                    type="checkbox"
                                    checkbox-all
                                )
                        th STT
                        th Mã đơn
                        th Khách hàng
                        th Sản phẩm
                        th Vị trí
                        th Tổng tiền
                        th Trạng thái
                        th Ngày tạo
                        th Hành động
                    tbody
                        each item, index in order
                            tr
                                td
                                    input(
                                        type="checkbox"
                                        checkbox-item
                                        name="id"
                                        value = item._id
                                    )
                                td #{index+1}
                                td #{item.order_id}
                                
                                td #{item.userInfo.userName}
                                td #{item.product.length}
                                td 
                                    if(roleAccount.permission.includes("order_edit"))
                                        input(
                                            position-input 
                                            value = item.position 
                                            min = 1
                                            type="number"
                                            name = "position"
                                            style="width:50px"
                                        )
                                    else 
                                        input(
                                            value = item.position 
                                            min = 1
                                            type="number"
                                            name = "position"
                                            style="width:50px"
                                        )
                                td(
                                    class="text-success"
                                ) #{item.totalPrice} VNĐ
                                td
                                    -if (item.status == "pending")
                                        a(
                                            href="javascript:;"
                                            class="badge bg-warning"
                                        ) Chờ xử lý
                                    -else if (item.status == "shipping")
                                        a(
                                            href="javascript:;"
                                            class="badge bg-info"
                                        ) Đang giao
                                    -else if (item.status == "finish")
                                        a(
                                            href="javascript:;"
                                            class="badge bg-success"
                                        ) Hoàn thành
                                    -else if(item.status=="canceled")
                                        a(
                                            href="javascript:;"
                                            class="badge bg-danger"
                                        ) Đã hủy
                                td 
                                    +date(item.createdBy.createdAt)

                                td
                                    a(
                                        class="btn btn-sm btn-primary"
                                        href=`${prefixAdmin}/orders/detail/${item._id}`
                                    ) Xem
        form(
            action=`${prefixAdmin}/orders/change-status`, 
            method="post",
            form-change-status
        ) 
        form(
            action = `${prefixAdmin}/orders/delete`
            method="post"
            form-delete
        )

        script(src="/admin/JS/product.js") 
        script(src="/admin/JS/order.js")
                            