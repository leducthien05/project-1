extends ../../layout/auth.pug
include ../../mixin/alert.pug

block content
    .login-container
        .card.login-card.shadow-sm
            .card-body
                img(
                    src="/images/logo.png"
                    alt="logo"
                    class="logo"
                )
                .text-center.mb-3
                    h4.text-center.mb-4 Đăng nhập hệ thống

                form(method="POST")
                    .mb-3
                        label(class="form-label") Email
                        input(
                            class="form-control"
                            type="email"
                            name="email"
                            placeholder="Nhập email..."
                            required
                        )

                    .mb-3
                        label(class="form-label") Mật khẩu
                        .input-group
                            input.form-control(
                                type="password"
                                name="password"
                                id="password"
                                placeholder="Nhập mật khẩu..."
                                required
                            )
                            button(
                                class="btn btn-outline-secondary"
                                type="button"
                                id="togglePassword"
                            ) 👁

                    .mb-3.form-check
                        input(
                            class="form-check-input"
                            type="checkbox" 
                            name="remember"
                        )
                        label(class="form-check-label") Ghi nhớ đăng nhập

                    button(
                        class="btn btn-primary w-100" 
                        type="submit"
                    ) Đăng nhập