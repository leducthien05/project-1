extends ../../layout/default.pug
include ../../mixin/filterStatus.pug
include ../../mixin/search.pug
include ../../mixin/pagination.pug
include ../../mixin/OptionChangeMulti.pug
include ../../mixin/alert.pug
include ../../mixin/sort.pug
include ../../mixin/convertTime.pug

block main
    +success(3000)
    if(roleAccount.permission.includes("user_view"))
        .card.shadow-sm
            .card-body
                    .row
                        .col-4
                            +sortUser
        .card.shadow-sm
            .card-body
                h5.mb-3 Bộ lọc và Tìm kiếm
                    .row.align-items-center
                        // Bộ lọc trạng thái
                        .col-md-6
                            +filterStatus(listStatus)
                        .col-md-6
                            +search(keyword)
        .card.shadow-sm
            .card-header.d-flex.justify-content-between.align-items-center
                //- h5.mb-0 Danh sách sản phẩm
                // Select hành động
                if(roleAccount.permission.includes("user_edit"))
                    form(
                        action=`${prefixAdmin}/users/change-multi-status?_method=PATCH` 
                        method="POST" 
                        form-change-multi
                        class="d-flex gap-2"
                    )
                        +selectOptionUser()

            .card-body

                table(
                    class="table table-hover table-sm"
                    style="font-size:12px;"
                    checkbox-multi
                )
                    thead
                        tr
                            th 
                                input(
                                    type="checkbox"
                                    checkbox-all
                                )
                            th STT
                            th Hình
                            th Tên người dùng
                            th Email 
                            th Số điện thoại
                            th Trạng thái
                            //- th Danh mục
                            th Hành động

                    tbody
                        each item, index in user
                            tr
                                td 
                                    input(
                                        type="checkbox"
                                        checkbox-item
                                        name="id"
                                        value = item.id
                                    )
                                
                                td #{item.indexUser}
                                td
                                    img(
                                        src=(item.avatar ? item.avatar : "https://i.pinimg.com/originals/c6/e5/65/c6e56503cfdd87da299f72dc416023d4.jpg")
                                        alt=item.userName
                                        hight= "auto"
                                        width = "60px"
                                        loading="lazy"
                                    )
                                td #{item.userName}
                                td #{item.email}
                                td #{item.phone}
                                td 
                                    if(roleAccount.permission.includes("user_edit"))
                                        if(item.status == "active")
                                            a(
                                                href="javascript:;"
                                                class="badge bg-success"
                                                change-status
                                                status=item.status
                                                id=item.id
                                            ) Hoạt động
                                        else
                                            a(
                                                href="javascript:;"
                                                class="badge bg-danger"
                                                change-status
                                                status=item.status
                                                id=item.id
                                            ) Ngừng hoạt động
                                    else 
                                        if(item.status == "active")
                                            a(
                                                href="javascript:;"
                                                class="badge bg-success"
                                                id=item.id
                                            ) Hoạt động
                                        else
                                            a(
                                                href="javascript:;"
                                                class="badge bg-danger"
                                                id=item.id
                                            ) Ngừng hoạt động
                                //- td Laptop
                                td
                                    a(
                                        href=`${prefixAdmin}/users/detail/${item.id}`
                                        class="btn btn btn-info btn-sm"
                                        id = item.id 
                                        detail
                                    ) Chi tiết
                                    if(roleAccount.permission.includes("user_edit"))
                                        a(
                                            href=`${prefixAdmin}/users/edit/${item.id}`
                                            class="btn btn-warning btn-sm"
                                            id = item.id 
                                            button-update
                                        ) Sửa
                                    if(roleAccount.permission.includes("user_delete"))
                                        button(
                                            class="btn btn-danger btn-sm"
                                            btn-delete
                                            btn-id = item.id
                                        ) Xóa
        +pagination(objectPage)
        form(
            action=`${prefixAdmin}/users/change-status`, 
            method="post",
            form-change-status
        ) 
        form(
            action = `${prefixAdmin}/users/delete`
            method="post"
            form-delete
        )

        script(src="/admin/JS/product.js") 
                            