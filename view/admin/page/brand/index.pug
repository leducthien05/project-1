extends ../../layout/default.pug
include ../../mixin/filterStatus.pug
include ../../mixin/search.pug
include ../../mixin/pagination.pug
include ../../mixin/OptionChangeMulti.pug
include ../../mixin/alert.pug
include ../../mixin/sort.pug
include ../../mixin/convertTime.pug

block main
    +success(3000)
    if(roleAccount.permission.includes("brand_view"))
        .card.shadow-sm
            .card-body
                    .row
                        .col-4
                            +sort
        .card.shadow-sm
            .card-body
                h5.mb-3 Bộ lọc và Tìm kiếm
                    .row.align-items-center
                        // Bộ lọc trạng thái
                        .col-md-6
                            +filterStatus(listStatus)
                        .col-md-6
                            +search(keyword)
        .card.shadow-sm
            .card-header.d-flex.justify-content-between.align-items-center
                //- h5.mb-0 Danh sách sản phẩm
                // Select hành động
                if(roleAccount.permission.includes("brand_edit"))
                    form(
                        action=`${prefixAdmin}/brands/change-multi-status?_method=PATCH` 
                        method="POST" 
                        form-change-multi
                        class="d-flex gap-2"
                    )
                        +selectOption()
                if(roleAccount.permission.includes("brand_create"))
                    a(
                        class = "btn btn-primary"
                        href=`${prefixAdmin}/brands/create`
                    ) + Thêm sản phẩm

            .card-body

                table(
                    class="table table-hover table-sm"
                    style="font-size:12px;"
                    checkbox-multi
                )
                    thead
                        tr
                            th 
                                input(
                                    type="checkbox"
                                    checkbox-all
                                )
                            th STT
                            th Hình
                            th Tên thương hiệu
                            th Người tạo 
                            th Người sửa
                            th Vị trí
                            th Trạng thái
                            //- th Danh mục
                            th Hành động

                    tbody
                        each item, index in brand
                            tr
                                td 
                                    input(
                                        type="checkbox"
                                        checkbox-item
                                        name="id"
                                        value = item.id
                                    )
                                
                                td #{item.indexBrand}
                                td
                                    img(
                                        src=item.image
                                        alt=item.title
                                        hight= "auto"
                                        width = "100px"
                                        loading="lazy"
                                    )
                                td #{item.title}
                                td 
                                    p #{item.fullName}
                                    if(item.createdBy && item.createdBy.createdAt)
                                        +date(item.createdBy.createdAt)
                                    else
                                        | —
                                td 
                                    p #{item.accountUpdated}
                                    if(item.updatedAt)
                                        +date(item.updatedAt)
                                    else
                                        | —
                                td 
                                    if(roleAccount.permission.includes("brand_edit"))
                                        input(
                                            position-input 
                                            value = item.position 
                                            min = 1
                                            type="number"
                                            name = "position"
                                            style="width:70px"
                                        )
                                    else 
                                        input(
                                            value = item.position 
                                            min = 1
                                            type="number"
                                            name = "position"
                                            style="width:70px"
                                        )
                                td 
                                    if(roleAccount.permission.includes("brand_edit"))
                                        if(item.status == "active")
                                            a(
                                                href="javascript:;"
                                                class="badge bg-success"
                                                change-status
                                                status=item.status
                                                id=item.id
                                            ) Hoạt động
                                        else
                                            a(
                                                href="javascript:;"
                                                class="badge bg-danger"
                                                change-status
                                                status=item.status
                                                id=item.id
                                            ) Ngừng hoạt động
                                    else 
                                        if(item.status == "active")
                                            a(
                                                href="javascript:;"
                                                class="badge bg-success"
                                                id=item.id
                                            ) Hoạt động
                                        else
                                            a(
                                                href="javascript:;"
                                                class="badge bg-danger"
                                                id=item.id
                                            ) Ngừng hoạt động
                                //- td Laptop
                                td
                                    a(
                                        href=`${prefixAdmin}/brands/detail/${item.id}`
                                        class="btn btn btn-info btn-sm"
                                        id = item.id 
                                        detail
                                    ) Chi tiết
                                    if(roleAccount.permission.includes("brand_edit"))
                                        a(
                                            href=`${prefixAdmin}/brands/edit/${item.id}`
                                            class="btn btn-warning btn-sm"
                                            id = item.id 
                                            button-update
                                        ) Sửa
                                    if(roleAccount.permission.includes("brand_delete"))
                                        button(
                                            class="btn btn-danger btn-sm"
                                            btn-delete
                                            btn-id = item.id
                                        ) Xóa
        +pagination(objectPage)
        form(
            action=`${prefixAdmin}/brands/change-status`, 
            method="post",
            form-change-status
        ) 
        form(
            action = `${prefixAdmin}/brands/delete`
            method="post"
            form-delete
        )

        script(src="/admin/JS/product.js") 
                            