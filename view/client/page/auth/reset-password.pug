extends ../../layout/auth.pug

block main
    .section-reset
        .reset-container
            h2.title Đổi mật khẩu

            p.desc Nhập mật khẩu mới của bạn

            form(
                method="POST" 
                action="/user/reset-password"
            )
                .form-group 
                    label(for="password") Mật khẩu mới
                    input(
                        type="text" 
                        name="email" 
                        value = email
                        readonly
                    )
                .form-group
                    label(for="password") Mật khẩu mới
                    input(
                        class="password" 
                        type="password" 
                        name="password" 
                        placeholder="Nhập mật khẩu mới..." 
                        required
                    )

                .form-group
                    label(for="confirmPassword") Xác nhận mật khẩu
                    input(
                        class="confirmPassword" 
                        type="password" 
                        name="confirmPassword" 
                        placeholder="Nhập lại mật khẩu..." 
                        required
                    )

                button(
                    class="btn-submit" 
                    type="submit"
                ) Cập nhật mật khẩu

            .extra
                a(href="/user/login") ← Quay lại đăng nhập