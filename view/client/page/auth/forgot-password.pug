extends ../../layout/auth.pug

block main
    .section-forgot
        .forgot-container
            h2.title Quên mật khẩu

            p.desc Nhập email của bạn để nhận link đặt lại mật khẩu

            form(
                method="POST" 
                action="/user/forgot-password"
            )
                .form-group
                    label(for="email") Email
                    input(
                        id="email" 
                        type="email" 
                        name="email" 
                        placeholder="Nhập email..." 
                        required
                    )

                button(
                    class="btn-submit" 
                    type="submit"
                ) Gửi yêu cầu

            .extra
                a(href="/user/login") ← Quay lại đăng nhập