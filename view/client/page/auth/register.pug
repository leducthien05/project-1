extends ../../layout/auth.pug

block main
    .auth-container
        .auth-box
            h2 Đăng ký

            form(
                method="POST" 
                action="/user/register"
            )
                .form-group
                    label Tên
                    input(
                        type="text" 
                        name="userName" 
                        required 
                        placeholder="Nhập tên"
                    )
                .form-group
                    label Email
                    input(
                        type="email" 
                        name="email" 
                        required 
                        placeholder="Nhập email"
                    )

                .form-group
                    label Mật khẩu
                    input(
                        type="password" 
                        name="password" 
                        required 
                        placeholder="Nhập mật khẩu"
                    )

                button(
                    class="btn-submit" 
                    type="submit"
                ) Đăng ký

            p(class="switch")
                | Đã có tài khoản?
                a(href="/user/login") Đăng nhập