mixin submenu(path, category)
    each item in category
        li(class= item.children && item.children.length > 0 ? 'has-children' : '')
            a(href= path + '/' + item.slug) #{item.name}
            if item.children && item.children.length > 0
                ul(class = "dropdown-menu-custom")
                    +submenu(path, item.children)