// views/client/layout/default.pug
doctype html
html(lang="vi")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title #{titlePage}

        // 🚀 preload CSS (tăng tốc)
        link(rel="preload" href="/client/css/main.min.css" as="style")
        link(rel="stylesheet" href="/client/style/auth.css")

        // Bootstrap (nếu dùng)
        link(
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
            rel="stylesheet"
        )

    body
        block main